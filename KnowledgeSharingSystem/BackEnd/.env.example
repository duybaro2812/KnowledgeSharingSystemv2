PORT=3000

# Security
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=1d
OTP_EXPIRE_MINUTES=10
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_DURATION_MINUTES=15
AUTH_ATTEMPT_STORE_MAX_SIZE=20000
RATE_LIMIT_MAX_BUCKETS=5000
ENABLE_ACCESS_LOG=true
SLOW_REQUEST_THRESHOLD_MS=1200

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
DB_CLIENT=postgres
DB_AUTH_MODE=sql
# Optional: prefer this on cloud hosting (Render/Neon/Supabase).
# If DATABASE_URL is set, DB_SERVER/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD are ignored.
DATABASE_URL=
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=KSS
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Upload / Preview
UPLOAD_DIR=uploads
DOCUMENT_PREVIEW_WORK_DIR=
DOCUMENT_PREVIEW_CONVERT_TIMEOUT_MS=120000
DOCUMENT_PREVIEW_FETCH_RETRY_ATTEMPTS=3
DOCUMENT_PREVIEW_FETCH_RETRY_DELAY_MS=350
DOCUMENT_PREVIEW_CONVERT_RETRY_ATTEMPTS=2
DOCUMENT_PREVIEW_CONVERT_RETRY_DELAY_MS=500
LIBREOFFICE_BIN=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_DOCUMENT_FOLDER=knowledge-sharing-system/documents

# Mail / OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
OTP_DEV_FALLBACK=true
